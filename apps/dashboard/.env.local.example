# WalletConnect Project ID — get one at cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Session encryption secret (32+ chars, random)
SESSION_SECRET=your-session-secret-at-least-32-characters-long

# Bittensor RPC (default: mainnet)
NEXT_PUBLIC_BITTENSOR_RPC=https://lite.chain.opentensor.ai

# Database path (SQLite, default: ./dashboard.db)
DATABASE_PATH=./dashboard.db
