{
  "name": "@peekaboopay/crypto",
  "version": "0.1.0",
  "publishConfig": { "access": "public" },
  "description": "Cryptographic primitives for Peek-a-boo — Poseidon hashing, Merkle trees, Groth16 proofs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@peekaboopay/tsconfig": "*"
  }
}
