{
  "name": "@pas/mcp-server",
  "version": "0.1.0",
  "description": "PAS MCP server — expose privacy tools to any MCP-compatible agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pas-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@pas/types": "*",
    "@pas/sdk": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@pas/tsconfig": "*"
  }
}
