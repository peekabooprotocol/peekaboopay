{
  "name": "@peekaboopay/adapter-railgun",
  "version": "0.1.0",
  "description": "Railgun privacy backend adapter — shielded ERC-20 via ZK-SNARKs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@peekaboopay/types": "*",
    "@railgun-community/wallet": "^10.8.1",
    "@railgun-community/shared-models": "^7.6.1",
    "ethers": "^6.16.0",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@peekaboopay/tsconfig": "*"
  }
}
