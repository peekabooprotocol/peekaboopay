{
  "name": "@pas/storage-sqlite",
  "version": "0.1.0",
  "description": "SQLite persistence backend for PAS core modules",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@pas/types": "*",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@pas/tsconfig": "*",
    "@types/better-sqlite3": "^7.6.0"
  }
}
